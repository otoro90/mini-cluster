# =============================================================================
# Mini-Cluster Forjanova Labs — Secretos del cluster
# =============================================================================
# Copia este archivo como "secrets.env" (gitignoreado) y rellena los valores.
# Guarda la copia maestra en Bitwarden: colección "mini-cluster / forjanova".
#
# USO: source ./secrets.env  (antes de ejecutar scripts de despliegue)
# =============================================================================

# ---------------------------------------------------------------------------
# SSH / Acceso al cluster
# ---------------------------------------------------------------------------
CLUSTER_SSH_PASS="123456"                    # root@192.168.1.210 (cambiar en producción)
MASTER_IP="192.168.1.210"
MASTER_USER="root"

# ---------------------------------------------------------------------------
# K3s
# ---------------------------------------------------------------------------
K3S_TOKEN="K10dd8855fe8c3ed719655efdf5310fc9c868c28802825dc239ddd110feb80adfec::server:dc42591fa3eeee232aca82dd70c2e542"

# ---------------------------------------------------------------------------
# Argo CD
# ---------------------------------------------------------------------------
ARGOCD_ADMIN_PASS="ipb4EnoshkInEr4g"        # admin en http://argocd.local

# ---------------------------------------------------------------------------
# Docker Registry LAN
# ---------------------------------------------------------------------------
REGISTRY_URL="registry.192.168.1.210.nip.io"
REGISTRY_USER="admin"
REGISTRY_PASS="Registry12345"

# ---------------------------------------------------------------------------
# ZITADEL (IdP — namespace: zitadel)
# ---------------------------------------------------------------------------
ZITADEL_URL="https://auth.forjanova.com"
# Contraseña de PostgreSQL dedicado para ZITADEL (K8s secret: zitadel-postgres-admin)
ZITADEL_PG_ADMIN_PASS="zitadel_pg_admin_ChangeMe_2026"
# La masterkey se genera aleatoriamente en el despliegue y vive en K8s secret: zitadel-masterkey
# Para recuperarla:
#   kubectl -n zitadel get secret zitadel-masterkey -o jsonpath='{.data.masterkey}' | base64 -d

# ---------------------------------------------------------------------------
# Headscale (VPN — namespace: headscale)
# ---------------------------------------------------------------------------
HEADSCALE_URL="https://vpn.forjanova.com"
HEADSCALE_STUN="192.168.1.210:30478"        # UDP

# OIDC con ZITADEL (se rellena en Fase 2 con setup-zitadel-oidc-headscale.sh)
HEADSCALE_OIDC_ISSUER=""                    # https://auth.forjanova.com
HEADSCALE_OIDC_CLIENT_ID=""                 # generado por ZITADEL
HEADSCALE_OIDC_CLIENT_SECRET=""             # generado por ZITADEL

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (para HTTPS público — opcional)
# ---------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=""                  # Zero Trust > Networks > Tunnels > <tu-tunnel>
CLOUDFLARE_DOMAIN=""                        # ej: forjanova.com — tu dominio en Cloudflare

# URLs públicas tras configurar el tunnel:
# ZITADEL_PUBLIC_URL="https://zitadel.${CLOUDFLARE_DOMAIN}"
# HEADSCALE_PUBLIC_URL="https://headscale.${CLOUDFLARE_DOMAIN}"

# ---------------------------------------------------------------------------
# App Tramites — DB (namespace: tramites-dev / tramites-prod)
# ---------------------------------------------------------------------------
TRAMITES_DB_USER_DEV="tramites"
TRAMITES_DB_PASS_DEV="tramites123dev"
TRAMITES_DB_USER_PROD="tramites"
TRAMITES_DB_PASS_PROD="CHANGE_IN_PROD"

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
GITOPS_PAT=""                               # PAT con repo write — usado en CI update-gitops
